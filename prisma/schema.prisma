generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String   @id @default(cuid())
  name             String?
  email            String   @unique
  password         String
  isPremium        Boolean  @default(false)
  stripeCustomerId String?
  orders           Order[]
}

model Order {
  id        String   @id @default(cuid())
  product   String
  amount    Int
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}