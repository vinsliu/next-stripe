# ------------------------------------------------------------------
# COMMENT UTILISER CE FICHIER :
# Il suffit de retirer ".example" à la fin du nom de ce fichier
# pour qu'il devienne ".env". Puis remplis les valeurs ci-dessous.
# ------------------------------------------------------------------

# Base de données (ne pas modifier, fonctionne tel quel)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# N'importe quelle suite de caractères aléatoires fait l'affaire.
NEXTAUTH_SECRET="remplace-moi-par-nimporte-quoi"

# Stripe (mode test) — clé à récupérer sur https://dashboard.stripe.com/test/apikeys
# Elle commence toujours par sk_test_
STRIPE_SECRET_KEY="sk_test_remplace_moi"

# Généré par la commande : stripe listen --forward-to localhost:3000/api/webhooks/stripe
# (voir l'étape 7 du README) — commence toujours par whsec_
STRIPE_WEBHOOK_SECRET="whsec_remplace_moi"
